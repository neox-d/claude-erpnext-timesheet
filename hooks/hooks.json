{
  "description": "Install the timesheet-setup CLI command on each session start",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/hooks-handlers/session-start.sh\"",
            "async": false
          }
        ]
      }
    ]
  }
}
